<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Night Sky Message</title>
    <style>
        body {
            margin: 0;
            background: radial-gradient(circle at bottom, #1B2735 0%, #090A0F 100%);
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
            font-family: 'Inter', -apple-system, sans-serif;
            color: white;
        }

        /* Latar Belakang Bintang */
        .stars {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            pointer-events: none;
        }
        .star {
            position: absolute;
            background: white;
            border-radius: 50%;
            opacity: 0.5;
            animation: twinkle var(--duration) infinite;
        }
        @keyframes twinkle {
            0%, 100% { opacity: 0.3; transform: scale(1); }
            50% { opacity: 1; transform: scale(1.2); }
        }

        .container {
            text-align: center;
            z-index: 10;
            padding: 20px;
        }

        /* Ikon Tenda yang Lucu */
        .tent {
            font-size: 75px;
            cursor: pointer;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            filter: drop-shadow(0 0 15px rgba(255, 255, 255, 0.2));
            display: inline-block;
        }
        .tent:hover { transform: scale(1.2) rotate(5deg); }

        /* Kotak Pesan Misterius */
        #message {
            display: none;
            margin-top: 25px;
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(15px);
            padding: 30px 20px;
            border-radius: 25px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            max-width: 280px;
            animation: slideUp 0.8s ease-out;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }

        @keyframes slideUp { 
            from { opacity: 0; transform: translateY(30px); } 
            to { opacity: 1; transform: translateY(0); } 
        }

        h2 { font-size: 1.1rem; margin-bottom: 12px; color: #f0f0f0; font-weight: 500; }
        p { font-size: 0.9rem; line-height: 1.6; color: #d1d1d1; margin-bottom: 20px; }
        
        /* Tombol WA yang Elegan & Lucu */
        .btn-wa {
            display: inline-block;
            background: #25d366;
            color: white;
            text-decoration: none;
            padding: 10px 22px;
            border-radius: 50px;
            font-size: 0.85rem;
            font-weight: 600;
            transition: 0.3s;
            box-shadow: 0 4px 15px rgba(37, 211, 102, 0.3);
        }
        .btn-wa:hover { 
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(37, 211, 102, 0.5);
        }
        
        .hint { font-size: 0.75rem; color: #888; margin-top: 15px; letter-spacing: 0.5px; }
    </style>
</head>
<body>

    <div class="stars" id="starField"></div>

    <div class="container">
        <div class="tent" id="tentBtn" onclick="openMessage()">⛺</div>
        <p id="instruction" class="hint">Ketuk tendanya...</p>

        <div id="message">
            <h2>Halaman Rahasia 🌌</h2>
            <p>Sengaja buat lanjutannya biar kamu nggak lupa istirahat. Jangan terlalu diforsir kuliahnya ya. Semangat terus!</p>
            
            <a href="https://wa.me/6281389295689?text=Baru%20buka%20halamannya.%20Ini%20siapa?%20Lucu%20banget%20kodenya." 
               target="_blank" class="btn-wa">
               Tebak siapa? 💬
            </a>

            <hr style="border: 0.5px solid rgba(255,255,255,0.05); margin: 20px 0;">
            <p style="font-size: 0.7rem; color: #666; margin: 0;">— Someone who cares.</p>
        </div>
    </div>

    <script>
        // Animasi Bintang Tabur
        const starField = document.getElementById('starField');
        for (let i = 0; i < 150; i++) {
            const star = document.createElement('div');
            star.className = 'star';
            star.style.left = Math.random() * 100 + '%';
            star.style.top = Math.random() * 100 + '%';
            const size = Math.random() * 2.5;
            star.style.width = size + 'px';
            star.style.height = size + 'px';
            star.style.setProperty('--duration', (Math.random() * 3 + 2) + 's');
            starField.appendChild(star);
        }

        // Fungsi Buka Pesan
        function openMessage() {
            document.getElementById('message').style.display = 'block';
            document.getElementById('tentBtn').style.display = 'none';
            document.getElementById('instruction').style.display = 'none';
        }
    </script>
</body>
</html> 